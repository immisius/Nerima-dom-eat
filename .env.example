# Railway / 本番環境用の環境変数サンプル
# Railway の Variables に以下を設定してください

# SQLite DB の保存先 (Railway Volume を /data にマウントした場合)
DB_PATH=/data/meals.db

# Google Calendar 連携 (オプション)
# credentials.json の中身をそのまま貼り付け
GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...",...}}
# token.json の中身をそのまま貼り付け (初回ローカル認証後にコピー)
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...",...}
# 同期先カレンダーID (省略時は primary)
GOOGLE_CALENDAR_ID=primary
